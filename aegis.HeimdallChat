#!/usr/bin/env python3
"""
aegis.HeimdallChat — qrexec RPC handler running inside sys-copilot.
Proxy chat and goal requests from authorized VMs to the running Heimdall Agent socket.
"""

import sys
import json
import socket
import os

HEIMDALL_SOCK = "/run/aegis/heimdall.sock"
MAX_INPUT_BYTES = 65536  # Max 64KB query request

def main():
    # 1. Read input with size cap
    raw_bytes = sys.stdin.buffer.read(MAX_INPUT_BYTES + 1)
    if len(raw_bytes) > MAX_INPUT_BYTES:
        sys.stderr.write("Error: Request too large.\n")
        sys.exit(1)
        
    raw = raw_bytes.decode("utf-8", errors="replace").strip()
    if not raw:
        sys.exit(0)
        
    # 2. Verify Heimdall Agent socket is available
    if not os.path.exists(HEIMDALL_SOCK):
        sys.stderr.write("Error: Heimdall Agent socket not available. Is the service running?\n")
        sys.exit(1)
        
    # 3. Parse request JSON or treat as raw text
    try:
        req = json.loads(raw)
        query = req.get("query", "")
    except Exception:
        query = raw

    if not query:
        sys.stderr.write("Error: Empty query.\n")
        sys.exit(1)

    payload = {"query": query}

    # 4. Connect to Heimdall agent socket and send query
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        s.connect(HEIMDALL_SOCK)
        s.sendall((json.dumps(payload) + "\n").encode('utf-8'))
        
        # Read response line
        buffer = b""
        s.settimeout(120)  # Heimdall agent loop (LLM + actions) can take up to 2 minutes
        while b"\n" not in buffer:
            chunk = s.recv(4096)
            if not chunk:
                break
            buffer += chunk
            
        if b"\n" in buffer:
            line = buffer.split(b"\n")[0]
            resp = json.loads(line.decode('utf-8'))
            print(json.dumps(resp), flush=True)
        else:
            sys.stderr.write("Error: Disconnected from Heimdall Agent socket without newline response.\n")
            sys.exit(1)
    except Exception as e:
        sys.stderr.write(f"Error communicating with Heimdall: {str(e)}\n")
        sys.exit(1)
    finally:
        s.close()

if __name__ == "__main__":
    main()
